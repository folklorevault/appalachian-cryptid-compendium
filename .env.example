# Appalachian Cryptid Compendium - Environment Variables
# Copy this file to .env.local and fill in your values

# Mapbox API Token (get one free at https://mapbox.com)
# Used for the interactive sighting map
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# Sanity CMS Configuration (get from https://sanity.io/manage)
# If not set, the app falls back to static data
NEXT_PUBLIC_SANITY_PROJECT_ID=8thljucm
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only variables (set in Vercel dashboard, not needed for local dev)
# SANITY_API_TOKEN=your_sanity_write_token
# SANITY_WEBHOOK_SECRET=your_webhook_secret
# LOOPS_API_KEY=your_loops_api_key

# Appalachian Cryptid Field Guide - Environment Variables
# Copy this file to .env and fill in your values

# Mapbox API Token (get one free at https://mapbox.com)
# Used for the interactive sighting map
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Sanity CMS Configuration (get from https://sanity.io/manage)
# If not set, the app falls back to static data
VITE_SANITY_PROJECT_ID=8thljucm
VITE_SANITY_DATASET=production

# Admin API Key (for Cloudflare Pages, set in dashboard)
# Used for sighting report moderation
# ADMIN_API_KEY=your_secret_admin_key
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.env|*.env.*|*/.env|*/.env.*) echo '{\"decision\":\"block\",\"reason\":\"Do not edit .env files\"}'; exit 0 ;; esac"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path // empty'); [ -n \"$f\" ] && npx eslint --fix \"$f\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
